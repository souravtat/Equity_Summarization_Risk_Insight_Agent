# Copy this file to .env and populate before running.
# The .env file is listed in .gitignore and must never be committed.

# ── Groq LLM (optional) ───────────────────────────────────────────────────
# Obtain a free API key at https://console.groq.com
# When unset the agent falls back to the lexicon + FAISS pipeline automatically.
GROQ_API_KEY=your_groq_api_key_here

# ── Evaluation scripts ────────────────────────────────────────────────────
# Override if the API server is running on a different host/port.
APP_BASE_URL=http://localhost:9060
